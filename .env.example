# Copy to .env and fill in. .env is git-ignored — NEVER commit real secrets.

# Where the API binds.
BIND_ADDR=0.0.0.0:8080

# Which operator is active: mock (today) | mtn | orange | wave (later).
DEFAULT_PROVIDER=mock

# Shared HMAC secret to sign/verify webhooks. Generate a strong random one:
#   openssl rand -hex 32
WEBHOOK_SECRET=dev-insecure-change-me

# --- The day you sign a contract, add the operator's real credentials here. ---
# Nothing above changes; you just fill these and flip DEFAULT_PROVIDER.
# MTN_SUBSCRIPTION_KEY=
# MTN_API_USER=
# MTN_API_KEY=
# ORANGE_CLIENT_ID=
# ORANGE_CLIENT_SECRET=
# WAVE_API_KEY=

# --- Later: real durable ledger (Supabase / Postgres). ---
# DATABASE_URL=postgres://user:pass@host:5432/dbname
